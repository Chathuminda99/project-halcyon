-- Halcyon intranet schema + seed data. Regenerated fresh on every deploy from
-- the randomized secrets, so shipment IDs/refs stay stable across deploys but
-- credentials and flag tokens never do.

DROP TABLE IF EXISTS shipments;
DROP TABLE IF EXISTS users;
DROP TABLE IF EXISTS integrations;

CREATE TABLE users (
    id SERIAL PRIMARY KEY,
    username TEXT UNIQUE NOT NULL,
    password TEXT NOT NULL,
    role TEXT NOT NULL,
    ops_team TEXT NOT NULL
);

CREATE TABLE shipments (
    id SERIAL PRIMARY KEY,
    reference TEXT NOT NULL,
    destination TEXT NOT NULL,
    status TEXT NOT NULL,
    ops_team TEXT NOT NULL,
    internal_notes TEXT
);

-- Legacy sync integration table: cached AD service credential, reachable via
-- the SQLi in /search when that path is live (UNION-based extraction).
CREATE TABLE integrations (
    id SERIAL PRIMARY KEY,
    name TEXT NOT NULL,
    ad_bind_dn TEXT,
    ad_bind_password TEXT,
    notes TEXT
);

